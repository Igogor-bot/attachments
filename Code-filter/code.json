// n8n Code node — Run Once for All Items
// Input:
//   items[0].json.data  -> Source CSV string (headers in first row)
// Output:
//   [{ json: { data: "<CSV in target structure>", contentType: "text/csv" } }]
// On missing CSV: [{ json: { data: "ERROR: missing input" } }]

// --- 1) Inputs ---
const inventoryCsv = (typeof items?.[0]?.json?.data === "string") ? items[0].json.data : null;
if (!inventoryCsv) {
  return [{ json: { data: "ERROR: missing input" } }];
}

// --- 2) Target CSV structure (exact header order) ---
const TARGET_COLUMNS = [
  "stock", "title", "vin", "year", "make", "model", "trim", "free_text", "type", "body",
  "mileage", "price_current", "price_wholesale", "price_cost", "InternetPrice", "MSRP", "BookValue",
  "exterior", "interior", "doors", "engine", "transmission", "drive_type", "fuel_type",
  "warranty", "warranty_description", "description", "pics", "condition", "options",
  "URL_YouTube", "URL_MAS", "date_in_stock", "DealerName", "DealerContactPerson", "DealerPhone",
  "DealerEmail", "DealerAddress", "DealerCity", "DealerState", "DealerZIP", "DealerCountry",
  "DealerID", "DealerLOT", "DealerGroup", "Certified", "CategorizedOptions", "MarketClass",
  "User_price1", "User_price2", "User_price3", "Comment1", "Comment2", "Comment3",
  "VIDEO_URL_1", "VIDEO_URL_2", "VIDEO_URL_3", "VehicleID", "DetailURL", "price_monthly",
  "mm_code", "license_plate", "sub_category", "engine_make", "engine_power", "brake_type",
  "truck_status", "trailer_status", "status_details", "over_drive", "suspension", "ratio",
  "tires", "wheels", "wheel_base", "Axles", "axle_type", "spread_axle", "front_axle", "rear_axle",
  "internal_height", "height", "length", "width", "sleeper_type", "insulated", "passengers", "sleeps",
  "doors_description", "side_doors", "gate", "dump_location", "flatbed", "cab", "composition",
  "tank_type", "floor", "extendable", "detachable", "bottom_load", "frame", "compartments",
  "pneumatic_size", "vapor_recover", "hoppers", "gallons", "reefer_manufacturer", "cars", "ballast",
  "payload", "steering", "size", "safety_chains", "coupler", "tongue", "deck_width", "deck_height",
  "ramps", "fenders", "charger", "type_of_motor", "air_conditioners", "slides", "water_capacity",
  "awnings", "gvwr", "dry_weight", "chassis", "jack", "self_contained", "generator", "price_header"
];

// --- 3) Helpers ---
function norm(s){ return String(s || "").toLowerCase().replace(/[^a-z0-9]/g, ""); }

function cleanFreeText(s){
  let t = String(s ?? "");
  t = t.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, "");
  t = t.replace(/EspaC1ol/gi, "Español");
  return t;
}

function csvEscape(v){
  const s = String(v ?? "");
  if (/[",\r\n]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
  return s;
}

function parseCsv(text){
  const rows = [];
  let i = 0, f = "", r = [], q = false;

  while (i < text.length){
    const c = text[i];

    if (q){
      if (c === '"'){
        if (text[i + 1] === '"'){ f += '"'; i++; }
        else q = false;
      } else {
        f += c;
      }
    } else {
      if (c === '"') q = true;
      else if (c === ","){ r.push(f); f = ""; }
      else if (c === "\r"){ /* ignore */ }
      else if (c === "\n"){ r.push(f); rows.push(r); f = ""; r = []; }
      else f += c;
    }

    i++;
  }

  r.push(f);
  rows.push(r);

  while (rows.length && rows[rows.length - 1].length === 1 && rows[rows.length - 1][0] === "") {
    rows.pop();
  }

  return rows;
}

// --- 4) Source-header synonyms ---
function buildSynonyms(){
  const m = {};
  const add = (target, headers) => { m[norm(target)] = headers.map(norm); };

  // Core identity
  add("stock", ["StockNumber","Stock","Stock #","Unit","UnitNumber"]);
  add("title", ["DisplayName","Title"]);
  add("vin", ["VINSerialNumber","VIN","SerialNumber","Vin"]);
  add("year", ["Year"]);
  add("make", ["Manufacturer","Make"]);
  add("model", ["Model"]);
  add("trim", ["Trim"]);

  // Text
  add("free_text", ["FreeText","Description","Comments","Comment","Notes"]);
  add("description", ["Description","VehicleDescriptionValues","FreeText","Comments","Notes"]);

  // Classification
  add("type", ["Category","InventoryType","ListingCategory","MotorizedType","Type"]);
  add("body", ["Category","BodyStyle","Body"]);

  // Specs
  add("mileage", ["Mileage","Odometer","Miles"]);
  add("exterior", ["ExteriorColor","Color","Exterior"]);
  add("interior", ["InteriorColor","Interior"]);
  add("doors", ["Doors"]);
  add("engine", ["Engine"]);
  add("transmission", ["Transmission","TransmissionType"]);
  add("drive_type", ["Drive","Drivetrain","DriveType"]);
  add("fuel_type", ["FuelType","Fuel"]);
  add("condition", ["Condition"]);

  // Pricing
  add("price_current", ["SaleListPrice","BuyNowPrice","StartingBidPrice","FloorPrice","InternetPrice","Price"]);
  add("InternetPrice", ["SaleListPrice","InternetPrice","BuyNowPrice","StartingBidPrice","FloorPrice"]);
  add("MSRP", ["MSRP"]);
  add("BookValue", ["BookValue"]);
  add("price_wholesale", ["WholesalePrice","PriceWholesale"]);
  add("price_cost", ["Cost","PriceCost"]);

  // Media
  add("pics", ["PictureList","Pics","Pictures","Images","ImageUrls"]);
  add("VIDEO_URL_1", ["VideoURL","VideoUrl","YouTubeURL","URL_YouTube"]);

  // Dealer / location
  add("DealerName", ["OwnerName","CompanyName","DealerName","PickUpDealerName"]);
  add("DealerContactPerson", ["RetailContactName","ContactName","DealerContactPerson","PickUpContactPerson"]);
  add("DealerPhone", ["RetailContactPhoneNumber","Phone","DealerPhone","PickUpPhone"]);
  add("DealerEmail", ["ContactEmail","DealerEmail","PickUpEmail"]);
  add("DealerAddress", ["LocationAddress","DealerAddress","PickUpAddress"]);
  add("DealerCity", ["LocationCity","DealerCity","PickUpCity"]);
  add("DealerState", ["LocationState","DealerState","PickUpState"]);
  add("DealerZIP", ["LocationPostalCode","DealerZIP","PickUpPostalCode"]);
  add("DealerCountry", ["LocationCountry","DealerCountry"]);
  add("DealerLOT", ["DSLocationName","DealerLOT"]);
  add("DealerID", ["RetailLeadGroupID","WholesaleLeadGroupID","RentalLeadGroupID","DealerID"]);
  add("DealerGroup", ["CreatedByNamespace","DealerGroup"]);

  // IDs / URLs
  add("VehicleID", ["DSLookupID","VehicleID"]);
  add("DetailURL", ["DetailURL","URL_MAS"]);
  add("URL_MAS", ["DetailURL","URL_MAS"]);
  add("date_in_stock", ["AcquisitionDate","date_in_stock"]);

  // Trailer / inventory-specific
  add("composition", ["composition"]);
  add("axle_type", ["axle","axle_type"]);
  add("Axles", ["axle","Axles"]);
  add("wheels", ["wheels"]);
  add("tires", ["tires"]);
  add("width", ["width"]);
  add("length", ["length"]);
  add("height", ["height"]);
  add("suspension", ["suspension"]);
  add("extendable", ["extendable"]);
  add("detachable", ["detachable"]);
  add("floor", ["floortype","floor"]);
  add("payload", ["maxpayload","payload"]);
  add("gvwr", ["grossvehicleweight","gvwr"]);
  add("dry_weight", ["weight","dry_weight"]);
  add("ramps", ["ramp","ramps"]);
  add("flatbed", ["Category"]);
  add("status_details", ["InventoryStatusDetails","status_details"]);
  add("trailer_status", ["InventoryStatus","trailer_status"]);
  add("sub_category", ["Category","sub_category"]);

  return m;
}

// --- 5) Parse source CSV ---
const rows = parseCsv(inventoryCsv);
if (!rows.length) return [{ json: { data: "ERROR: missing input" } }];

const headers = rows[0].map(h => String(h || "").trim());
const dataRows = rows.slice(1);
const synonyms = buildSynonyms();

function rowToNormMap(arr){
  const map = new Map();

  for (let i = 0; i < headers.length; i++){
    const k = norm(headers[i]);
    if (!k) continue;
    if (!map.has(k)) map.set(k, arr[i] == null ? "" : String(arr[i]));
  }

  // Convenience aliases
  if (map.has("manufacturer") && !map.has("make")) map.set("make", map.get("manufacturer"));
  if (map.has("vinserialnumber") && !map.has("vin")) map.set("vin", map.get("vinserialnumber"));
  if (map.has("description") && !map.has("freetext")) map.set("freetext", map.get("description"));
  if (map.has("salelistprice") && !map.has("internetprice")) map.set("internetprice", map.get("salelistprice"));
  if (map.has("ownername") && !map.has("dealername")) map.set("dealername", map.get("ownername"));
  if (map.has("retailcontactphonenumber") && !map.has("dealerphone")) map.set("dealerphone", map.get("retailcontactphonenumber"));
  if (map.has("retailcontactname") && !map.has("dealercontactperson")) map.set("dealercontactperson", map.get("retailcontactname"));
  if (map.has("dslocationname") && !map.has("dealerlot")) map.set("dealerlot", map.get("dslocationname"));
  if (map.has("dslookupid") && !map.has("vehicleid")) map.set("vehicleid", map.get("dslookupid"));
  if (map.has("retailleadgroupid") && !map.has("dealerid")) map.set("dealerid", map.get("retailleadgroupid"));
  if (map.has("locationaddress") && !map.has("dealeraddress")) map.set("dealeraddress", map.get("locationaddress"));
  if (map.has("locationcity") && !map.has("dealercity")) map.set("dealercity", map.get("locationcity"));
  if (map.has("locationstate") && !map.has("dealerstate")) map.set("dealerstate", map.get("locationstate"));
  if (map.has("locationpostalcode") && !map.has("dealerzip")) map.set("dealerzip", map.get("locationpostalcode"));
  if (map.has("locationcountry") && !map.has("dealercountry")) map.set("dealercountry", map.get("locationcountry"));
  if (map.has("detailurl") && !map.has("urlmas")) map.set("urlmas", map.get("detailurl"));
  if (map.has("acquisitiondate") && !map.has("dateinstock")) map.set("dateinstock", map.get("acquisitiondate"));
  if (map.has("inventorystatusdetails") && !map.has("statusdetails")) map.set("statusdetails", map.get("inventorystatusdetails"));
  if (map.has("inventorystatus") && !map.has("trailerstatus")) map.set("trailerstatus", map.get("inventorystatus"));

  return map;
}

function getValue(rowMap, targetCol){
  const key = norm(targetCol);

  // direct match first
  if (rowMap.has(key)) return rowMap.get(key);

  // synonym match
  const syn = synonyms[key];
  if (syn){
    for (const h of syn){
      if (rowMap.has(h)) return rowMap.get(h);
    }
  }

  return "";
}

function buildOutputRow(rowMap){
  const out = [];

  for (const col of TARGET_COLUMNS){
    const k = norm(col);

    // pics: keep raw PictureList
    if (k === "pics"){
      let raw = "";
      if (rowMap.has("picturelist")) raw = rowMap.get("picturelist");
      else raw = getValue(rowMap, col);
      out.push(csvEscape(raw));
      continue;
    }

    // clean free text fields
    if (k === "freetext" || k === "free_text" || k === "description"){
      const v = cleanFreeText(getValue(rowMap, col));
      out.push(csvEscape(v));
      continue;
    }

    // explicit mappings for new feed IDs / fields
    if (k === "vehicleid"){
      out.push(csvEscape(getValue(rowMap, "VehicleID")));
      continue;
    }

    if (k === "dealerid"){
      out.push(csvEscape(getValue(rowMap, "DealerID")));
      continue;
    }

    if (k === "title"){
      out.push(csvEscape(getValue(rowMap, "title")));
      continue;
    }

    if (k === "dealercountry"){
      out.push(csvEscape(getValue(rowMap, "DealerCountry")));
      continue;
    }

    if (k === "dealerlot"){
      out.push(csvEscape(getValue(rowMap, "DealerLOT")));
      continue;
    }

    if (k === "dateinstock" || k === "date_in_stock"){
      out.push(csvEscape(getValue(rowMap, "date_in_stock")));
      continue;
    }

    if (k === "urlmas"){
      out.push(csvEscape(getValue(rowMap, "URL_MAS")));
      continue;
    }

    if (k === "videourl1" || k === "video_url_1"){
      out.push(csvEscape(getValue(rowMap, "VIDEO_URL_1")));
      continue;
    }

    if (k === "trailerstatus" || k === "trailer_status"){
      out.push(csvEscape(getValue(rowMap, "trailer_status")));
      continue;
    }

    if (k === "statusdetails" || k === "status_details"){
      out.push(csvEscape(getValue(rowMap, "status_details")));
      continue;
    }

    // flatbed helper from Category text
    if (k === "flatbed"){
      const cat = getValue(rowMap, "body");
      out.push(csvEscape(/flatbed/i.test(cat) ? "True" : ""));
      continue;
    }

    // normal pass-through
    out.push(csvEscape(getValue(rowMap, col)));
  }

  return out.join(",");
}

// --- 6) Build final CSV ---
const lines = [];
lines.push(TARGET_COLUMNS.map(csvEscape).join(","));

for (const rowArr of dataRows){
  const rowMap = rowToNormMap(rowArr);
  lines.push(buildOutputRow(rowMap));
}

const finalCsv = lines.join("\r\n");
return [{ json: { data: finalCsv, contentType: "text/csv" } }];
